/* Обращаемся напрямую к нашему классу */
QWidget#MainWindow {
    background-color: #1e1e1e; /* Глубокий темно-серый */
    border: none;              /* На всякий случай убираем рамки */
}

/* Если внутри появятся другие виджеты, зададим им базовый цвет текста */
QWidget {
    color: #d4d4d4;
    font-family: "Segoe UI", sans-serif;
}